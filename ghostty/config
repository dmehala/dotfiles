# Shell
command = fish
shell-integration = fish

# Font
font-size = 14
font-feature = -calt
font-feature = -liga
font-feature = -dlig
# font-family             = "FiraCode Nerd Font Mono"
# font-style              = "Retina"

# Bold
# font-family-bold        = "FiraCode Nerd Font Mono"
# font-style-bold         = "Bold"

# Italic
# font-family-italic      = "FiraCode Nerd Font Mono"
# font-style-italic       = "Italic"

# Bold and Italic
# font-family-bold-italic = "FiraCode Nerd Font Mono"
# font-style-bold-italic  = "ExtraBold Italic"

# Keybinds
## NOTE: super is command on mac
keybind = super+ctrl+v=new_split:right
keybind = super+ctrl+h=new_split:down
keybind = super+k=goto_split:top
keybind = super+j=goto_split:bottom
keybind = super+l=goto_split:right
keybind = super+h=goto_split:left
keybind = ctrl+t=new_tab
keybind = ctrl+w=close_surface
keybind = super+shift+enter=toggle_split_zoom

keybind = super+ctrl+left=resize_split:left,20
keybind = super+ctrl+down=resize_split:down,20
keybind = super+ctrl+up=resize_split:up,20
keybind = super+ctrl+right=resize_split:right,20

keybind = global:cmd+grave_accent=toggle_quick_terminal

# Misc
macos-titlebar-style    = tabs
macos-option-as-alt     = true
mouse-hide-while-typing = true

clipboard-read = allow
clipboard-write = allow
copy-on-select = clipboard

unfocused-split-opacity = 1

# Quick Terminal
quick-terminal-position = top

confirm-close-surface = false
theme = GitHub Dark
